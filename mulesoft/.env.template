# ============================================
# PropHub MuleSoft API - Environment Variables
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.template .env
# 2. Fill in your actual credentials
# 3. NEVER commit the .env file to git!
# ============================================

# ---- Salesforce Login Credentials ----
# Your normal Salesforce login username and password.
# Security Token: Setup > My Personal Information > Reset My Security Token
# (Salesforce emails you the token - paste it here)

SF_USERNAME=your-salesforce-login@example.com
SF_PASSWORD=your-salesforce-password
SF_SECURITY_TOKEN=your-security-token-from-email

# Demo user email (must match Presales_User__mdt record)
SF_DEMO_USER_EMAIL=demo@prophub.com

# ---- MuleSoft Anypoint Platform ----
# THESE are the only values that change when trial expires
ANYPOINT_USERNAME=your-anypoint-username
ANYPOINT_PASSWORD=your-anypoint-password

# ---- CloudHub Deployment ----
CLOUDHUB_APP_NAME=prophub-api
CLOUDHUB_ENVIRONMENT=Sandbox
CLOUDHUB_REGION=us-east-2

# ---- JWT Secret (for PropHub mobile app token signing) ----
JWT_SECRET=change-this-to-a-random-string-min-32-chars

# ---- Optional: Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id

# ---- Optional: Anypoint API Manager ----
ANYPOINT_CLIENT_ID=your-client-id
ANYPOINT_CLIENT_SECRET=your-client-secret
