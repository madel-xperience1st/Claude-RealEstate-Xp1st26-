<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns:os="http://www.mulesoft.org/schema/mule/os"
      xmlns:salesforce="http://www.mulesoft.org/schema/mule/salesforce"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd
        http://www.mulesoft.org/schema/mule/os http://www.mulesoft.org/schema/mule/os/current/mule-os.xsd
        http://www.mulesoft.org/schema/mule/salesforce http://www.mulesoft.org/schema/mule/salesforce/current/mule-salesforce.xsd">

    <!-- ============================================ -->
    <!-- PROCESS: Validate JWT Token                   -->
    <!-- Called by every secured endpoint               -->
    <!-- ============================================ -->
    <sub-flow name="process-validate-token">
        <set-variable variableName="authHeader"
                      value="#[attributes.headers.authorization default '']" />

        <choice>
            <when expression="#[vars.authHeader startsWith 'Bearer ']">
                <set-variable variableName="token"
                              value="#[vars.authHeader replace 'Bearer ' with '']" />

                <!-- Check if token exists in our store -->
                <os:contains key="#[vars.token]"
                             objectStore="Token_Store"
                             target="tokenValid" />

                <choice>
                    <when expression="#[vars.tokenValid]">
                        <!-- Retrieve user data from token -->
                        <os:retrieve key="#[vars.token]"
                                     objectStore="Token_Store"
                                     target="currentUser" />
                        <logger level="DEBUG" message="Token valid for user: #[vars.currentUser]" />
                    </when>
                    <otherwise>
                        <raise-error type="PROPHUB:UNAUTHORIZED"
                                     description="Token not found or expired" />
                    </otherwise>
                </choice>
            </when>
            <otherwise>
                <raise-error type="PROPHUB:UNAUTHORIZED"
                             description="Missing or invalid Authorization header" />
            </otherwise>
        </choice>
    </sub-flow>

    <!-- ============================================ -->
    <!-- PROCESS: Auth Token Exchange                   -->
    <!-- Validates Google ID token, checks whitelist,   -->
    <!-- generates PropHub JWT                          -->
    <!-- ============================================ -->
    <sub-flow name="process-auth-token">
        <!-- For presales demo: we validate against Presales_User__mdt -->
        <!-- In production, you'd validate the Google ID token via     -->
        <!-- Google's tokeninfo endpoint first                         -->

        <!-- Step 1: Query Presales_User__mdt to check if email is whitelisted -->
        <!-- For demo mode, we extract email from the token payload            -->
        <!-- In a real setup, decode the Google JWT to get email               -->
        <set-variable variableName="demoEmail" value="${sf.demo.user.email}" />

        <flow-ref name="system-query-presales-user" />

        <set-variable variableName="presalesUser" value="#[payload]" />

        <choice>
            <when expression="#[sizeOf(vars.presalesUser) > 0]">
                <!-- User is whitelisted - look up their Contact record -->
                <flow-ref name="system-query-contact-by-email" />

                <set-variable variableName="contactRecord" value="#[payload]" />

                <!-- Generate access token (UUID-based for simplicity) -->
                <ee:transform>
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
var accessToken = uuid()
var refreshToken = uuid()
var user = vars.presalesUser[0]
var contact = if (sizeOf(vars.contactRecord) > 0) vars.contactRecord[0] else null
---
{
    accessToken: accessToken,
    refreshToken: refreshToken,
    expiresIn: 3600,
    user: {
        id: contact.PropHub_User_Id__c default user.DeveloperName,
        email: user.Google_Email__c,
        displayName: user.Display_Name__c,
        role: user.Role__c,
        contactId: contact.Id default ""
    }
}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>

                <!-- Store both tokens in ObjectStore for validation -->
                <set-variable variableName="authResponse" value="#[payload]" />

                <os:store key="#[vars.authResponse.accessToken]"
                          objectStore="Token_Store">
                    <os:value>#[output application/json --- vars.authResponse.user]</os:value>
                </os:store>

                <os:store key="#[vars.authResponse.refreshToken]"
                          objectStore="Token_Store">
                    <os:value>#[output application/json --- vars.authResponse.user]</os:value>
                </os:store>

                <set-payload value="#[vars.authResponse]" mimeType="application/json" />
            </when>
            <otherwise>
                <raise-error type="PROPHUB:FORBIDDEN"
                             description="User not whitelisted in Presales_User__mdt" />
            </otherwise>
        </choice>
    </sub-flow>

    <!-- ============================================ -->
    <!-- PROCESS: Generate new JWT from refresh         -->
    <!-- ============================================ -->
    <sub-flow name="process-generate-jwt">
        <ee:transform>
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
var newToken = uuid()
---
{
    accessToken: newToken,
    expiresIn: 3600
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>

        <set-variable variableName="newAuthResponse" value="#[payload]" />

        <!-- Store new token with user data -->
        <os:store key="#[vars.newAuthResponse.accessToken]"
                  objectStore="Token_Store">
            <os:value>#[output application/json --- vars.userData]</os:value>
        </os:store>

        <set-payload value="#[vars.newAuthResponse]" mimeType="application/json" />
    </sub-flow>

</mule>
