# Environment credentials - NEVER commit
.env
!.env.template
*.env.local

# Keystore files (contain private keys) - NEVER commit
**/keystore/*.jks
**/keystore/*.p12
**/keystore/*.crt
**/keystore/*.pem
!**/keystore/.gitkeep

# Maven build output
**/target/
*.jar
*.class

# IDE files
.idea/
*.iml
.project
.classpath
.settings/
.vscode/

# MuleSoft Studio
.mule/
*.dat

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
